{
  "name": "fin_project",
  "version": "1.0.0",
  "description": "Client-facing marketplace import portal for Amazon, Shopify, and spreadsheet order exports",
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "tsx watch src/server.ts",
    "dev:ui": "vite --config ui/vite.config.ts",
    "build": "tsc && tsc -p ui/tsconfig.json && vite build --config ui/vite.config.ts",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit && tsc -p ui/tsconfig.json --noEmit",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
